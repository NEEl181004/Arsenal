  },
  {
    "type": "p",
    "text": "",
    "images": []
  },
  {
    "type": "p",
    "text": "Set Audit Rules",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": []
  },
  {
    "type": "p",
    "text": "auditctl -w /etc/sudoers -p wa -k privilege_audit",
    "images": []
  },
  {
    "type": "p",
    "text": "auditctl -a always,exit -F arch=b64 -S execve -C uid!=euid -k privilege_escalation",
    "images": []
  },
  {
    "type": "p",
    "text": "auditctl -w /etc/passwd -p wa -k user_changes",
    "images": []
  },
  {
    "type": "p",
    "text": "auditctl -w /etc/group -p wa -k group_changes",
    "images": []
  },

  {
    "type": "p",
    "text": "1.2 Privilege Auditing",
    "images": []
  },
  {
    "type": "p",
    "text": "aim:-Audit user/service account privileges against least privilegeExpected output :- Access and privilege audit results.Tool:-auditd",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": []
  },
  {
    "type": "p",
    "text": "Privilege Auditing with auditd",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": []
  },
  {
    "type": "p",
    "text": "Install & Start auditd",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": []
  },
  {
    "type": "p",
    "text": "sudo apt update && sudo apt install auditd -y",
    "images": []
  },
  {
    "type": "p",
    "text": "sudo systemctl enable --now auditd",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": []
  },

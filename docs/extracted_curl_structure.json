  },
  {
    "type": "p",
    "text": "",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": [
      "image35.png"
    ]
  },
  {
    "type": "p",
    "text": "Purpose: Examines cookies for framework-specific naming patterns.",
    "images": []
  },
  {
    "type": "p",
    "text": "Execution Details:",
    "images": []
  },
  {
    "type": "p",
    "text": "Focuses on Set-Cookie headers which often contain framework-specific identifiers",
    "images": []
  },
  {
    "type": "p",
    "text": "Expected Output: Cookie names that may indicate technologies (PHPSESSID, JSESSIONID, ASP.NET_SessionId).",
    "images": []
  },
  {
    "type": "p",
    "text": "Security Implications: Framework identification enables targeted attacks against known framework vulnerabilities.",

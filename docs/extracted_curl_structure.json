  },
  {
    "type": "p",
    "text": "SESSION1=$(grep -i \"sessionid\" session1.txt | awk '{print $NF}')",
    "images": []
  },
  {
    "type": "p",
    "text": "SESSION2=$(grep -i \"sessionid\" session2.txt | awk '{print $NF}')",

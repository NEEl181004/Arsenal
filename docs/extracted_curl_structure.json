  },
  {
    "type": "p",
    "text": "5.2.2 Test HTTP Method Support",
    "images": []
  },
  {
    "type": "p",
    "text": "curl -s -X OPTIONS https://example.com -i | grep -i allow",
    "images": []
  },
  {
    "type": "p",
    "text": "",
    "images": [
      "image25.png"
    ]
  },
  {
    "type": "p",
    "text": "Purpose: Determines which HTTP methods are supported by the server.",
    "images": []
  },
  {
    "type": "p",

    "type": "p",
    "text": "6. Troubleshooting",
    "images": []
  },
  {
    "type": "p",
    "text": "Common Errors:",
    "images": []
  },
  {
    "type": "p",
    "text": "SSL/TLS Errors:",
    "images": []
  },
  {
    "type": "p",
    "text": "Issue: SSL certificate verification problems",
    "images": []
  },
  {
    "type": "p",
    "text": "Solution: Use --no-check-certificate option",
    "images": []
  },
  {
    "type": "p",
    "text": "Slow or Hanging Scans:",
    "images": []
  },
  {
    "type": "p",
    "text": "Issue: Scan taking too long or hanging",
    "images": []
  },
  {
    "type": "p",
    "text": "Solution: Reduce aggression level with -a or set a timeout with --max-run-time",
    "images": []
  },
  {
    "type": "p",
    "text": "Memory Issues:",
    "images": []
  },
  {
    "type": "p",
    "text": "Issue: Out of memory when scanning large sites",
    "images": []
  },
  {
    "type": "p",
    "text": "Solution: Reduce the number of threads with --max-threads or scan smaller batches",
    "images": []
  },
  {
    "type": "p",
    "text": "Plugin Errors:",
    "images": []
  },
  {
    "type": "p",
    "text": "Issue: Plugin failures",
    "images": []
  },
  {
    "type": "p",
    "text": "Solution: Update WhatWeb to the latest version or disable problematic plugins with --disable-plugin",
    "images": []
  },
  {
    "type": "p",
    "text": "Debugging:",
    "images": []
  },
  {
    "type": "p",
    "text": "Use -v for verbose output",
    "images": []
  },
  {
    "type": "p",
    "text": "Use --debug for detailed debugging information",
    "images": []
  },
  {
    "type": "p",
    "text": "Check plugin errors with --log-errors option",
    "images": []
  },
